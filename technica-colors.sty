\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{technica-colors}[2026/06/23 Technica color palette]

% ------------------------------------------------------------------------------
% Purpose
% ------------------------------------------------------------------------------
% Defines the Technica named color palette and a lightweight alias system.
% Raw colors own a hex value; semantic tokens alias into raw colors so that
% redefining a raw color propagates to all aliases automatically.
%
% Public interface:
%   \technicadefinecolor{<name>}{<RRGGBB>}
%     Defines a raw color and a \<name>Hex macro for the hex string.
%     If called after package load, replays all alias bindings.
%
%   \technicaaliascolor{<name>}{<target>}
%     Binds <name> to <target> via \colorlet and registers the binding
%     for replay when <target> is later redefined.
% ------------------------------------------------------------------------------

\RequirePackage{kvoptions}
\SetupKeyvalOptions{family=technica, prefix=technica@colors@}

\DeclareStringOption[light]{theme}

\ProcessKeyvalOptions*

\RequirePackage[table,dvipsnames,svgnames,x11names]{xcolor}

\makeatletter

% false during initial load; true after
\newif\iftechnica@colors@loaded

% accumulates \technica@refreshalias calls
\newcommand{\technica@aliases}{}

\newcommand{\technica@refreshalias}[2]{%
    \colorlet{#1}{#2}%
    \expandafter\edef\csname #1Hex\endcsname{\csname #2Hex\endcsname}%
}

\newcommand{\technicadefinecolor}[2]{%
    \definecolor{#1}{HTML}{#2}%
    \expandafter\def\csname #1Hex\endcsname{#2}%
    \iftechnica@colors@loaded\technica@aliases\fi
}

\newcommand{\technicaaliascolor}[2]{%
    \technica@refreshalias{#1}{#2}%
    \g@addto@macro\technica@aliases{\technica@refreshalias{#1}{#2}}%
}

\InputIfFileExists{themes/technica-colors-\technica@colors@theme.def}{}{%
    \PackageError{technica-colors}{%
        Theme `\technica@colors@theme' not found%
    }{%
        No file themes/technica-colors-\technica@colors@theme.def on the TeX path.%
        Shipping themes: light, dark.%
    }%
}

\AtEndOfPackage{\technica@colors@loadedtrue}

\makeatother

\endinput
