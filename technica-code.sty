\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{technica-code}[2026/06/25 Technica code and terminal styles]

% ------------------------------------------------------------------------------
% Purpose
% ------------------------------------------------------------------------------
% Owns shared code presentation: base listings defaults, code-box styling, and
% language loading. Per-language keyword/style data lives in languages/*.def so
% adding Python, JSON, Rust, etc. does not turn this module into a keyword dump.
%
% Public API:
%   \technicaloadcodelanguage{<name>}
%     Loads languages/<name>.def once. Shipping languages: cxx, sh.
%
%   \technicadefinecodeblock{<environment>}{<listings-style>}
%     Defines a titled tcolorbox/listings environment taking one title argument.
%
%   \technicadefineinlinecode{<command>}{<listings-style>}
%     Defines an inline code command backed by a listings style.
%
%   \inlinecode{...}     generic inline code
%   \inlinecxx{...}      inline C++ (from languages/cxx.def)
%   \inlinesh{...}       inline shell/terminal text (from languages/sh.def)
%
%   \begin{codeblock}{Title} ... \end{codeblock}
%   \begin{cxx}{main.cpp} ... \end{cxx}      (from languages/cxx.def)
%   \begin{terminal} ... \end{terminal}      (from languages/sh.def)
% ------------------------------------------------------------------------------

\RequirePackage{kvoptions}
\SetupKeyvalOptions{family=technica, prefix=technica@code@}

% ------------------------------------------------------------------------------
% Package options
% ------------------------------------------------------------------------------
% languages:   Comma-separated language definition names to load from languages/.
%              Empty disables built-in language loading.
%
% arc:         Corner radius passed to tcolorbox.
% boxrule:     Border width for code boxes.
%
% left, right, top, bottom:
%              Interior padding values passed to tcolorbox.
%
% beforeskip, afterskip:
%              Vertical skips around code boxes.
% ------------------------------------------------------------------------------

\DeclareStringOption[cxx,sh]{languages}
\DeclareStringOption[3pt]{arc}
\DeclareStringOption[0.6pt]{boxrule}
\DeclareStringOption[8pt]{left}
\DeclareStringOption[8pt]{right}
\DeclareStringOption[8pt]{top}
\DeclareStringOption[8pt]{bottom}
\DeclareStringOption[10pt plus 2pt minus 1pt]{beforeskip}
\DeclareStringOption[10pt plus 2pt minus 1pt]{afterskip}

\ProcessKeyvalOptions*

\RequirePackage{technica-colors}
\RequirePackage{listings}
\RequirePackage{textcomp}
\RequirePackage[many]{tcolorbox}

\tcbuselibrary{listings,breakable,skins}

\makeatletter

\lstdefinestyle{technica-base}{
    basicstyle=\ttfamily\small\color{TechnicaInk},
    backgroundcolor=\color{TechnicaCodeBg},
    columns=fullflexible,
    keepspaces=true,
    upquote=true,
    showspaces=false,
    showtabs=false,
    showstringspaces=false,
    breakatwhitespace=true,
    breaklines=true,
    tabsize=4,
    frame=none,
    aboveskip=0pt,
    belowskip=0pt
}

\tcbset{
    technica-codebox/.style={
        enhanced,
        breakable,
        arc=\technica@code@arc,
        boxrule=\technica@code@boxrule,
        colback=TechnicaCodeBg,
        colframe=TechnicaCodeBorder,
        coltitle=TechnicaInk,
        colbacktitle=TechnicaCodeBg,
        fonttitle=\ttfamily\small\bfseries,
        attach boxed title to top left={xshift=8pt,yshift=-2pt},
        boxed title style={
            empty,
            left=0pt,
            right=0pt,
            top=0pt,
            bottom=0pt
        },
        left=\technica@code@left,
        right=\technica@code@right,
        top=\technica@code@top,
        bottom=\technica@code@bottom,
        before skip=\technica@code@beforeskip,
        after skip=\technica@code@afterskip
    }
}

\newtcblisting{codeblock}[1]{
    listing engine=listings,
    listing only,
    listing options={style=technica-base},
    technica-codebox,
    title={#1},
}

\newcommand{\technicadefinecodeblock}[2]{%
    \newtcblisting{#1}[1]{%
        listing engine=listings,
        listing only,
        listing options={style=#2},
        technica-codebox,
        title={##1},
    }%
}

\newcommand{\technicadefineinlinecode}[2]{%
    \expandafter\newcommand\csname #1\endcsname[1]{%
        \lstinline[style=#2,escapechar=|]|##1|%
    }%
}

\newcommand{\technicaloadcodelanguage}[1]{%
    \@ifundefined{technica@code@language@#1@loaded}{%
        \InputIfFileExists{languages/#1.def}{%
            \expandafter\gdef\csname technica@code@language@#1@loaded\endcsname{1}%
        }{%
            \PackageError{technica-code}{Code language `#1' not found}{%
                No file languages/#1.def was found on the TeX path.%
            }%
        }%
    }{}%
}

% Inline generic code intentionally remains language-neutral.
\newcommand{\inlinecode}[1]{\lstinline[style=technica-base]|#1|}

\ifx\technica@code@languages\@empty\else
    \@for\technica@code@language:=\technica@code@languages\do{%
        \technicaloadcodelanguage{\technica@code@language}%
    }%
\fi

\makeatother

\endinput
