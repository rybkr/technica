\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{technica-code}[2026/06/23 Technica code and terminal styles]

% This module owns code presentation.
%
% Public API:
%   \inlinecode{...}     generic inline code
%   \inlinecxx{...}      inline C++
%   \inlinesh{...}       inline shell/terminal text
%
%   \begin{codeblock}{Title} ... \end{codeblock}
%   \begin{cxx}{main.cpp} ... \end{cxx}
%   \begin{terminal} ... \end{terminal}
%
% Notes:
% - Add languages by defining new listings styles and thin environments.
% - Keep semantic aliases such as cxx/python/json separate from the visual
%   defaults so documents can stay stable when the theme changes.

\RequirePackage{listings}
\RequirePackage[many]{tcolorbox}

\tcbuselibrary{listings,breakable}

\lstdefinestyle{technica-base}{
  basicstyle=\ttfamily\small,
  backgroundcolor=\color{TechnicaCodeBg},
  showspaces=false,
  showtabs=false,
  showstringspaces=false,
  breakatwhitespace=true,
  breaklines=true,
  tabsize=4,
  frame=none,
  aboveskip=0pt,
  belowskip=0pt
}

\newtcblisting{codeblock}[1]{
  listing engine=listings,
  listing only,
  listing options={style=technica-base},
  colback=TechnicaCodeBg,
  colframe=TechnicaCodeBorder,
  boxrule=0.8pt,
  title={#1},
  fonttitle=\centering\itshape\ttfamily,
  breakable,
  arc=4pt,
  left=6pt,
  right=6pt,
  top=6pt,
  bottom=6pt
}

\lstdefinestyle{technica-cxx}{
  style=technica-base,
  language=C++,
  commentstyle=\color{TechnicaComment}\itshape,
  stringstyle=\color{TechnicaString},
  numbers=left,
  numbersep=5pt,
  numberstyle=\color{TechnicaCodeBorder}\footnotesize\ttfamily,
  keywords=[2]{auto,bool,char,double,float,int,long,short,signed,unsigned,void},
  keywords=[3]{asm,catch,class,concept,const,consteval,constexpr,constinit,continue,decltype,default,do,enum,explicit,extern,for,friend,goto,inline,mutable,namespace,noexcept,override,private,protected,public,register,requires,return,static,struct,template,try,throw,typedef,typeid,typename,union,using,virtual,volatile,while},
  keywords=[4]{if,case,else,switch},
  keywords=[5]{and,and_eq,bitor,bitand,compl,delete,or,or_eq,new,not,not_eq,sizeof,xor,xor_eq},
  keywords=[6]{NULL,false,nullptr,true},
  keywords=[7]{this},
  keywords=[8]{operator},
  keywordstyle=[2]\color{TechnicaType},
  keywordstyle=[3]\color{TechnicaKeyword},
  keywordstyle=[4]\color{TechnicaKeyword}\itshape,
  keywordstyle=[5]\color{TechnicaOperator},
  keywordstyle=[6]\color{TechnicaLiteral},
  keywordstyle=[7]\color{TechnicaLiteral},
  keywordstyle=[8]\color{TechnicaOperator}
}

\newtcblisting{cxx}[1]{
  listing engine=listings,
  listing only,
  listing options={style=technica-cxx},
  colback=TechnicaCodeBg,
  colframe=TechnicaCodeBorder,
  boxrule=0.8pt,
  title={#1},
  fonttitle=\centering\itshape\ttfamily,
  breakable,
  arc=4pt,
  left=6pt,
  right=6pt,
  top=6pt,
  bottom=6pt
}

\lstdefinestyle{technica-terminal}{
  style=technica-base,
  backgroundcolor=\color{TechnicaTerminalBg},
  alsoletter={/.+-},
  keywords=[1]{$},
  keywords=[2]{clang++,g++,cmake,make,ninja,git,grep,rg,cat,diff,wc,objdump,./a.out},
  sensitive=true,
  keywordstyle=[1]\color{TechnicaPrompt},
  keywordstyle=[2]\color{TechnicaCommand},
  stringstyle=\color{TechnicaOperator}
}

\newtcblisting{terminal}{
  listing engine=listings,
  listing only,
  listing options={style=technica-terminal},
  colback=TechnicaTerminalBg,
  colframe=black,
  boxrule=0.5pt,
  title=Terminal,
  fonttitle=\centering\bfseries\ttfamily,
  breakable,
  arc=4pt,
  left=6pt,
  right=6pt,
  top=6pt,
  bottom=6pt
}

% Inline forms intentionally use semantic names so prose remains stable even if
% the implementation switches from listings to another highlighter later.
\newcommand{\inlinecode}[1]{\lstinline[style=technica-base]|#1|}
\newcommand{\inlinecxx}[1]{\lstinline[style=technica-cxx,escapechar=|]|#1|}
\newcommand{\inlinesh}[1]{\lstinline[style=technica-terminal]|#1|}

\endinput
